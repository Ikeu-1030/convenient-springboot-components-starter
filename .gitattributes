# Auto detect text files and perform LF normalization
* text=auto

# Java
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Maven
*.cmd text eol=crlf
mvnw text eol=lf

# Binary
*.jar binary
*.png binary
*.jpg binary
*.gif binary
